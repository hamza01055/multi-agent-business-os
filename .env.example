# --- Core ---
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# --- LLM ---
LLM_PROVIDER=openai            # openai | local
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
LOCAL_LLM_BASE_URL=http://ollama:11434/v1
LOCAL_LLM_MODEL=llama3.1

# --- Embeddings / Vectors ---
EMBEDDINGS_PROVIDER=sentence-transformers   # sentence-transformers | openai
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_BACKEND=faiss           # faiss | milvus
VECTOR_DIR=/data/vectors
MILVUS_URI=http://milvus:19530

# --- Infra ---
DATABASE_URL=postgresql+asyncpg://aibos:aibos@db:5432/aibos
SYNC_DATABASE_URL=postgresql+psycopg://aibos:aibos@db:5432/aibos
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=50

# --- Speech / OCR ---
WHISPER_MODEL=base
OCR_LANGS=eng

# --- Push ---
FCM_CREDENTIALS_JSON=
